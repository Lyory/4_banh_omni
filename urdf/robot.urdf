<?xml version="1.0"?>
<robot name="robot">
  <link name="base_link">
    <inertial>
      <origin xyz="-3.24159650053057E-07 -2.77555756156289E-17 -0.0880190321011237" rpy="0 0 0" />
      <mass value="1.60871892135771" />
      <inertia ixx="0.003820857251224" ixy="-5.45945661495239E-17" ixz="-1.03129716330073E-08" iyy="0.0038208610045686" iyz="7.20214372703818E-20" izz="0.0070632727871881" />
    </inertial>
    <visual>
